                  "    pm.expect(product).to.have.property('description');\r",
                  "\r",
                  "})});\r",
                  "\r",
                  "pm.test(\"Tipos de dados corretos\", function () {\r",
                  "\r",
                  "response.forEach(product => { \r",
                  "\r",
